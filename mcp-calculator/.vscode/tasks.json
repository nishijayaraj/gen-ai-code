{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run MCP Calculator (stdio)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source dev-env/bin/activate && python \"${workspaceFolder}/calculator.py\" --transport stdio"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "List MCP Tools",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source dev-env/bin/activate && python \"${workspaceFolder}/calculator.py\" --list-tools"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
